{
  "pluginAlias": "LegrandMyHome",
  "pluginType": "platform",
  "headerDisplay": "Plugin Homebridge per BTicino MyHome OpenWebNet (WHO=18) con compatibilità Eve per potenza istantanea e consumo totale.",
  "footerDisplay": "Per i tipi di accessorio supportati e il significato dell'indirizzo, consulta il README del plugin.",
  "schema": {
    "type": "object",
    "properties": {
      "ipaddress": {
        "title": "Indirizzo IP gateway MyHome",
        "type": "string",
        "required": true,
        "description": "Indirizzo IP del gateway OpenWebNet (es. F454, MH202)"
      },
      "port": {
        "title": "Porta",
        "type": "integer",
        "required": true,
        "default": 20000
      },
      "ownpassword": {
        "title": "Password OWN",
        "type": "string",
        "required": true
      },
      "discovery": {
        "title": "Discovery",
        "type": "boolean",
        "default": false
      },
      "devices": {
        "title": "Dispositivi",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "accessory": {
              "title": "Tipo accessorio",
              "type": "string",
              "required": true,
              "oneOf": [
                { "title": "Relay (luce/relè ON-OFF)", "enum": ["MHRelay"] },
                { "title": "Presa (Outlet)", "enum": ["MHOutlet"] },
                { "title": "Relay luce", "enum": ["MHRelayLight"] },
                { "title": "Dimmer", "enum": ["MHDimmer"] },
                { "title": "Tenda semplice (F411)", "enum": ["MHBlind"] },
                { "title": "Tenda avanzata (F401)", "enum": ["MHBlindAdvanced"] },
                { "title": "Termostato (F430)", "enum": ["MHThermostat"] },
                { "title": "Termometro esterno", "enum": ["MHExternalThermometer"] },
                { "title": "Sensore contatto (F428)", "enum": ["MHContactSensor"] },
                { "title": "Misuratore potenza/consumo (WHO=18)", "enum": ["MHPowerMeter"] },
                { "title": "Scenario", "enum": ["MHScene"] }
              ]
            },
            "name": {
              "title": "Nome",
              "type": "string",
              "required": true
            },
            "address": {
              "title": "Indirizzo",
              "type": "string",
              "required": true,
              "description": "Indirizzo OpenWebNet del dispositivo, es. 0/1/5 per luci/tende/prese, oppure numerico per termostati/sensori/power meter"
            },
            "scene": {
              "title": "Numero scenario",
              "type": "string",
              "description": "Solo per accessori di tipo Scenario"
            },
            "time": {
              "title": "Tempo di movimento (secondi)",
              "type": "integer",
              "description": "Solo per tende e alcuni misuratori"
            },
            "manufacturer": {
              "title": "Produttore (mostrato nell'app Home)",
              "type": "string",
              "description": "Solo per misuratori di potenza"
            },
            "model": {
              "title": "Modello (mostrato nell'app Home)",
              "type": "string",
              "description": "Solo per misuratori di potenza"
            }
          }
        }
      }
    }
  }
}
